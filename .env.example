# Committed template values
APP_NAME=qwen-tts-api
APP_ENV=development
APP_LOG_LEVEL=DEBUG

QWEN_TTS_MODEL_DEFAULT=Qwen/Qwen3-TTS-12Hz-0.6B-Base
QWEN_TTS_MODEL_ALLOWED=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign,Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice,Qwen/Qwen3-TTS-12Hz-1.7B-Base,Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice,Qwen/Qwen3-TTS-12Hz-0.6B-Base

QWEN_STT_MODEL_DEFAULT=whisper-1
QWEN_STT_MODEL_ALLOWED=whisper-1

# Max characters accepted by server before semantic chunking (must be >= 256)
QWEN_TTS_MAX_INPUT_CHARS=4096

# Preferred: path to external JSON map file (voice -> {ref_audio_path, ref_text, language})
QWEN_TTS_VOICE_MAP_FILE=./config/voice_map.example.json
