APP_NAME=llm-tts-api
APP_ENV=development
APP_LOG_LEVEL=DEBUG

TTS_PROVIDER=mlx_audio
TTS_MODEL_DEFAULT=Qwen/Qwen3-TTS-12Hz-0.6B-Base
TTS_MODEL_ALLOWED=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign,Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice,Qwen/Qwen3-TTS-12Hz-1.7B-Base,Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice,Qwen/Qwen3-TTS-12Hz-0.6B-Base,voxtral/mini-tts

STT_MODEL_DEFAULT=whisper-1
STT_MODEL_ALLOWED=whisper-1

# Max characters accepted by server before semantic chunking (must be >= 256)
TTS_MAX_INPUT_CHARS=4096

# Preferred: path to external JSON map file (voice -> {ref_audio_path, ref_text, language})
TTS_VOICE_MAP_FILE=./config/voice_map.example.json

